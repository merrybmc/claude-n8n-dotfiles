      "typeVersion": 2,
      "position": [900, 300],
      "notes": "글자수가 100자 이하면 '짧은 명언', 초과하면 '긴 명언'으로 분기합니다."
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "field-5",
              "name": "최종메시지",
              "value": "=\"[짧고 강렬한 명언] \" + $json.메시지",
              "type": "string"
            },
            {
              "id": "field-6",
              "name": "태그",
              "value": "short",
              "type": "string"
            }
          ]
