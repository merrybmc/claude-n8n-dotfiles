      "typeVersion": 4.2,
      "position": [460, 300],
      "notes": "quotable.io 무료 API에서 랜덤 명언을 가져옵니다."
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "field-1",
              "name": "명언",
              "value": "={{ $json.content }}",
              "type": "string"
            },
            {
              "id": "field-2",
              "name": "작가",
              "value": "={{ $json.author }}",
              "type": "string"
            },
            {
              "id": "field-3",
              "name": "글자수",
              "value": "={{ $json.length }}",
              "type": "number"
            },
            {
              "id": "field-4",
              "name": "메시지",
              "value": "=\"오늘의 명언: \" + $json.content + \" - \" + $json.author",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "필요한 데이터만 추출",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [680, 300],
      "notes": "API 응답에서 필요한 필드만 골라서 새로운 형태로 만듭니다."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-1",
              "leftValue": "={{ $json.글자수 }}",
              "rightValue": 100,
              "operator": {
                "type": "number",
                "operation": "lte"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "짧은 명언인가?",
